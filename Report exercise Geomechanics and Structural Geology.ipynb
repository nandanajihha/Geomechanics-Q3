   "metadata": {},
   "source": [
    "**Step 1: Stress Field Calculation**\n",
    "\n",
    "The stress field was computed on a 2D grid by superposing the contribution of both crack tips. The opening stress component ($\\sigma_y$) was retained because it controls Mode I crack opening."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "3bd43a7c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Full crack stress field calculated:\n",
      "  Crack: -5.0 cm to 5.0 cm (length = 10.0 cm)\n",
      "  Max opening stress (sigma_y): 271.0 MPa\n",
      "  (Occurs at theta=0, directly ahead of crack tips)\n"
     ]
    }
   ],
   "source": [
    "# Step 1: Calculating stress field for full crack with both tips\n",
    "\n",
    "def calculate_tip_stress(X, Y, tip_x, flip=False):\n",
    "    \"\"\"Calculate LEFM stress field from a single crack tip (Slide 19)\"\"\"\n",
    "    # Polar coordinates from tip\n",
    "    X_local = -(X - tip_x) if flip else (X - tip_x)\n",
    "    R = np.maximum(np.sqrt(X_local**2 + Y**2), 0.0001)\n",
    "    theta = np.arctan2(Y, X_local)\n",
    "\n",
    "    # Polar stress components (Mode I)\n",
    "    coeff = K_I / np.sqrt(2 * np.pi * R)\n",
    "    cos_half = np.cos(theta/2)\n",
    "    sin_half = np.sin(theta/2)\n",
    "\n",
    "    sigma_r = coeff * cos_half * (1 + sin_half**2)\n",
    "    sigma_theta = coeff * cos_half * cos_half**2\n",
    "    tau_r_theta = coeff * cos_half * np.sin(theta)\n",
    "\n",
    "    # Transform to Cartesian (sigma_x, sigma_y from sigma_r, sigma_theta)\n",
    "    cos_t = np.cos(theta)\n",
    "    sin_t = np.sin(theta)\n",
    "\n",
    "    # Stress transformation equations (tensor rotation)\n",
    "    sigma_x = sigma_r * cos_t**2 + sigma_theta * sin_t**2 - 2*tau_r_theta * sin_t*cos_t\n",
    "    sigma_y = sigma_r * sin_t**2 + sigma_theta * cos_t**2 + 2*tau_r_theta * sin_t*cos_t  # Opening stress!\n",
    "\n",
    "    return sigma_x, sigma_y\n",
    "\n",
    "# Create grid\n",
    "x = np.linspace(-0.07, 0.07, 300)\n",
    "y = np.linspace(-0.03, 0.03, 300)\n",
    "X, Y = np.meshgrid(x, y)\n",
    "\n",
    "# Stress from left tip (-a) and right tip (+a)\n",
    "sigma_x_left, sigma_y_left = calculate_tip_stress(X, Y, -a, flip=False)\n",
    "sigma_x_right, sigma_y_right = calculate_tip_stress(X, Y, a, flip=True)\n",
    "\n",
    "# Superposition\n",
    "sigma_x = sigma_x_left + sigma_x_right\n",
    "sigma_y = sigma_y_left + sigma_y_right\n",
    "\n",
    "# Mask crack region\n",
    "crack_mask = (np.abs(Y) < 0.0005) & (X >= -a) & (X <= a)\n",
    "sigma_y[crack_mask] = np.nan\n",
    "\n",
    "print(f\"Full crack stress field calculated:\")\n",
    "print(f\"  Crack: {-a*100:.1f} cm to {a*100:.1f} cm (length = {2*a*100:.1f} cm)\")\n",
    "print(f\"  Max opening stress (sigma_y): {np.nanmax(sigma_y):.1f} MPa\")\n",
    "print(f\"  (Occurs at theta=0, directly ahead of crack tips)\")"
   ]
  },
