   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "#parameters\n",
    "\n",
    "E = 15e9          # Young modulus (Pa) -> 15 GPa\n",
    "nu = 0.25         # Poisson ratio\n",
    "gamma = 100         # surface energy (J/m^2)\n",
    "sigma_h = 26e6    # horizontal stress (Pa) -> 26 MPa\n",
    "\n",
    "# different fracture lenght\n",
    "a_cm = np.array([0.1, 0.5, 1, 5, 10, 50])\n",
    "a = a_cm / 100\n",
    "\n",
    "#corrected Young modulus for plane strain\n",
    "\n",
    "E_prime = E / (1 - nu**2)\n",
    "\n",
    "print(\"E' =\", E_prime/1e9, \"GPa\")\n",
    "\n",
    "#sigma critical: \n",
    "\n",
    "sigma_crit = np.sqrt((2 * gamma * E_prime) / (np.pi * a *(1-nu**2)))\n",
    "\n",
    "\n",
    "sigma_crit_MPa = sigma_crit / 1e6\n",
    "\n",
    "print(\"\\nResults :\")\n",
    "for i in range(len(a)):\n",
    "    print(f\"a = {a_cm[i]} cm  ->  sigma_crit = {sigma_crit_MPa[i]:.2f} MPa\")\n",
    "\n",
    "#graph \n",
    "\n",
    "plt.figure()\n",
    "\n",
    "plt.plot(a_cm, sigma_crit_MPa, marker='o', label=\"Critical stress\")\n",
    "plt.axhline(y=26, linestyle=\"--\", label=\"σh = 26 MPa\")\n",
    "\n",
    "plt.xlabel(\"Fracture length a (cm)\")\n",
    "plt.ylabel(\"Critical stress σcrit (MPa)\")\n",
    "plt.title(\"Critical stress vs fracture length\")\n",
    "plt.legend()\n",
    "\n",
    "plt.show()"
   ]
  },
