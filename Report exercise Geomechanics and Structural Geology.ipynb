    "axes[2].set_title('Differential Stress (σ₁-σ₃)', fontsize=12)\n",
    "axes[2].invert_yaxis()\n",
    "axes[2].grid(alpha=0.3)\n",
    "axes[2].legend(fontsize=9, loc='upper right')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
