    "axes[1].plot(sigma_3_uniform, z_uniform, 'g--', linewidth=2, alpha=0.5, label='σ₃ (Uniform density 2650 kg/m³, nu = 0.25)')\n",
    "axes[1].set_xlabel('Stress (MPa)', fontsize=11)\n",
    "axes[1].set_ylabel('Depth (m)', fontsize=11)\n",
