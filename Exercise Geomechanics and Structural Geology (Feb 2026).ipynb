    "\n",
    "# Plot\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "\n",
    "\n",
    "# Data points\n",
    "ax.plot(sigma_3, sigma_1, 'o', markersize=8, label='Experimental Data', color='blue')\n",
