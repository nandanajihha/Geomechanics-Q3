    "axes[0].plot(phi, z, 'b-', linewidth=2)\n",
    "axes[0].set_xlabel('Porosity (%)', fontsize=11)\n",
    "axes[0].set_ylabel('Depth (m)', fontsize=11)\n",
    "axes[0].set_title('Porosity Profile in Fictive Layered System', fontsize=12)\n",
    "axes[0].invert_yaxis()\n",
    "axes[0].grid(alpha=0.3)\n",
